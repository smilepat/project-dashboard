# 아래를 복사해서 .env.local 파일을 만들고 실제 값을 채우세요.
# .env.local은 절대 GitHub에 올라가지 않습니다 (.gitignore에 등록됨).

# GitHub 사용자명 (본인 계정)
GITHUB_USERNAME=smilepat

# GitHub Personal Access Token (fine-grained PAT)
# 발급: https://github.com/settings/tokens?type=beta
#   - Repository access: All repositories
#   - Permissions → Contents: Read-only
# ⚠️ 값은 따옴표 없이 붙여넣을 것 (예: GITHUB_TOKEN=github_pat_xxx  ← "" 감싸지 말기)
# ⚠️ fine-grained PAT은 만료일이 있음 → 401이 뜨면 토큰 만료부터 의심하고 재발급.
#    재발급 시 Vercel 환경변수의 GITHUB_TOKEN도 함께 교체할 것(production도 같은 토큰).
GITHUB_TOKEN=github_pat_여기에_실제_토큰

# 대시보드에 표시할 프로젝트 repo 이름들 (쉼표로 구분)
# 비워두면 내 모든 repo를 자동으로 찾습니다.
TARGET_REPOS=

# 대시보드 접근 비밀번호 (Basic Auth, 아이디는 admin 고정).
# ⚠️ 이 앱은 private repo 내용을 노출하므로, 공개 배포(Vercel) 시 반드시 설정할 것.
#    설정하면 사이트 접근 시 admin / 이 비밀번호 입력을 요구합니다.
#    비워두면 인증 게이트가 비활성화됩니다(로컬 개발용).
DASH_PASSWORD=
